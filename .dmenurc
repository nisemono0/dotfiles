#!/bin/bash

FN="Noto-9:bold"
NF="$(xrdb -query | grep -w "*color4" | cut -f 2)"
NB="$(xrdb -query | grep -w "*color0" | cut -f 2)"
SF="$(xrdb -query | grep -w "*color7" | cut -f 2)"
SB="$(xrdb -query | grep -w "*color1" | cut -f 2)"
OPTIONS="-b -i -fn $FN -nf $NF -nb $NB -sf $SF -sb $SB"
export OPTIONS

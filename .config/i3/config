# i3 config file (v4)
# Please see http://i3wm.org/docs/userguide.html for a complete reference!


##---Basic---##
gaps inner 10
gaps outer 5
smart_borders on
hide_edge_borders on

set $mod Mod4
set $term --no-startup-id /usr/bin/urxvt
set $ranger --no-startup-id /usr/bin/urxvt -e /usr/bin/ranger
set $thunar --no-startup-id /usr/bin/thunar &
set $ncmpcpp --no-startup-id /usr/bin/urxvt -e /usr/bin/ncmpcpp
set $lockscreen --no-startup-id ~/.scripts/i3cmds/lock-screen.sh
set $dmenumount --no-startup-id ~/.scripts/i3cmds/dmenumount.sh
set $dmenuumount --no-startup-id ~/.scripts/i3cmds/dmenuumount.sh

font pango:InconsolataGo Nerd Font 10

##---Windows Rules---##
# Use xprop to find the window class
for_window [class=".*"] border pixel 3
for_window [class="floating"] move position center
for_window [title="ncmpcpp"] floating enable sticky enable focus

##---Autostart---##
exec --no-startup-id ~/.config/mpd/launch.sh
exec --no-startup-id ~/.scripts/tools/startup/urxvt-load.sh
exec --no-startup-id ~/.scripts/tools/startup/monitor-setup.sh
exec --no-startup-id compton -CG -b 
exec --no-startup-id dunst &
exec_always --no-startup-id hsetroot -full ~/.config/wallpaper.png
exec_always --no-startup-id ~/.config/polybar/launch.sh

##---Basic Keys---##
floating_modifier $mod
bindsym $mod+Return split horizontal ;; exec $term
bindsym $mod+t split toggle
bindsym $mod+slash split vertical ;; exec $term
bindsym $mod+shift+slash split horizontal ;; exec $term
bindsym $mod+Shift+Return exec $ranger
bindsym $mod+Shift+Control+Return exec $thunar
bindsym $mod+q kill
bindsym $mod+d exec --no-startup-id ~/.scripts/i3cmds/dmenu-bind.sh
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+Shift+Escape exec --no-startup-id "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -b 'Yes, exit i3' 'i3-msg exit'"

##---Workspace Keys---##
# Switch to workspace
bindsym $mod+1 workspace 1
bindsym $mod+2 workspace 2
bindsym $mod+3 workspace 3
bindsym $mod+4 workspace 4
bindsym $mod+5 workspace 5
bindsym $mod+6 workspace 6
bindsym $mod+7 workspace 7
bindsym $mod+8 workspace 8
bindsym $mod+9 workspace 9
bindsym $mod+0 workspace 10
# Move focused window to workspace
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10
# Others
bindsym $mod+comma workspace prev
bindsym $mod+period workspace next
bindsym $mod+shift+comma move container to workspace prev
bindsym $mod+shift+preriod move container to workspace next

##---Container Keys---##
# Change focused container
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
# Move focused container
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
# Resize focused container by 1
bindsym $mod+Ctrl+Right resize shrink width 5 px or 5 ppt
bindsym $mod+Ctrl+Up resize grow height 5 px or 5 ppt
bindsym $mod+Ctrl+Down resize shrink height 5 px or 5 ppt
bindsym $mod+Ctrl+Left resize grow width 5 px or 5 ppt
# Resize focused container by 10
bindsym $mod+Ctrl+Shift+Right resize shrink width 10 px or 10 ppt
bindsym $mod+Ctrl+Shift+Up resize grow height 10 px or 10 ppt
bindsym $mod+Ctrl+Shift+Down resize shrink height 10 px or 10 ppt
bindsym $mod+Ctrl+Shift+Left resize grow width 10 px or 10 ppt
# Toggle tiling/floating
bindsym $mod+Shift+space floating toggle
# Change focus between tiling/floating containers
bindsym $mod+space focus mode_toggle
# Fullscreen the focused container
bindsym $mod+f fullscreen toggle
# Move focused container to center
bindsym $mod+c move position center
# Focus the parent container
bindsym $mod+a focus parent

##---Function Keys---##
bindsym $mod+F1 exec --no-startup-id /usr/bin/firefox
bindsym $mod+F2 exec --no-startup-id notify-send F2
bindsym $mod+F3 exec --no-startup-id notify-send F3
bindsym $mod+F4 exec --no-startup-id notify-send F4
bindsym $mod+F5 exec --no-startup-id notify-send F5
bindsym $mod+F6 exec --no-startup-id notify-send F6
bindsym $mod+F7 exec --no-startup-id notify-send F7
bindsym $mod+F8 exec --no-startup-id notify-send F8
bindsym $mod+F9 exec $ncmpcpp
bindsym $mod+F10 exec $lockscreen
bindsym $mod+F11 exec $dmenumount
bindsym $mod+F12 exec $dmenuumount

##---Media Keys---##
bindsym XF86AudioPrev exec --no-startup-id mpc prev &
bindsym XF86AudioPlay exec --no-startup-id mpc toggle &
bindsym XF86AudioNext exec --no-startup-id mpc next &
bindsym XF86AudioMute exec --no-startup-id mpc volume 0 &
bindsym XF86AudioLowerVolume exec --no-startup-id mpc volume -10 &
bindsym XF86AudioRaiseVolume exec --no-startup-id mpc volume +10 &

##---Screenshot Keys---##
# Full screen
bindsym Print exec --no-startup-id ~/.scripts/tools/scrot/scrot.sh
bindsym Shift+Print exec --no-startup-id ~/.scripts/tools/scrot/scrot-clip.sh
# Window
bindsym Ctrl+Print exec --no-startup-id ~/.scripts/tools/scrot/scrot-area.sh
bindsym Ctrl+Shift+Print exec --no-startup-id ~/.scripts/tools/scrot/scrot-area-clip.sh


[colors]
; Bar color
background = ${xrdb:color0}
background-alt = #444

; Bar color alternative
foreground = ${xrdb:color7}
foreground-alt = #555

; Underline color
primary = ${xrdb:color5}
secondary = #FFF

; Alert color
alert = #bd2c40

[bar/top-bar]
width = 100%
height = 27
radius = 0.0
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

line-size = 3
line-color = #f00

border-size = 4
border-color = #00000000

padding-left = 1
padding-right = 1

module-margin-left = 1
module-margin-right = 1

font-0 = "xos4 Terminus:style=Regular;2"
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = siji:pixelsize=10;1
font-3 = "Ricty Nerd Font:style=Regular:size=10:antialas=false;0" 
modules-left = mpd
modules-center = i3
modules-right = filesystem alsa xkeyboard memory cpu cpu-temp-script eth date powermenu

tray-position = right
tray-padding = 2
cursor-click = pointer
cursor-scroll = ns-resize


; Left-Workspace
[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.primary}

; focused = Active workspace on focused monitor
label-focused = %index%
label-focused-background = ${colors.background-alt}
label-focused-underline = ${colors.primary}
label-focused-padding = 2

; unfocused = Inactive workspace on any monitor
label-unfocused = %index%
label-unfocused-padding = 2

; visible = Active workspace on unfocused monitor
label-visible = %index%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %index%
label-urgent-background = ${colors.alert}
label-urgent-padding = 2

; Middle-mpd
[module/mpd]
type = internal/mpd

label = <label-song> <icon-[random|repeat|repeatone]> <bar-progress>

format-online = <label-song> <icon-prev> <icon-stop> <toggle> <icon-next> <bar-progress> <label-time>
label-song = %artist% - %title%
label-song-font = 3
bar-progress-width = 15
bar-progress-indicator = |
bar-progress-fill = ‚ĒÄ
bar-progress-empty = ‚ĒÄ

label-offline = ūüéú mpd is offline
icon-prev = ÓāĖ
icon-stop = Óāô
icon-play = Óāö
icon-pause = Óāõ
icon-next = Óāú
label-song-maxlen = 23
label-song-ellipsis = true


; Right-filesystem
[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}


; Right-alsa
[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL %percentage%%
label-volume-foreground = ${colors.foreground}

format-muted-prefix = "Óąā "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 0
bar-volume-fill = ‚ĒÄ
bar-volume-fill-font = 0
bar-volume-empty = ‚ĒÄ
bar-volume-empty-font = 0
bar-volume-empty-foreground = ${colors.foreground-alt}


; Right-keyboard
[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "ÓČĮ "
format-prefix-foreground = ${colors.foreground-alt}
;format-prefix-underline = ${colors.secondary}

label-layout = %layout%
;label-layout-underline = ${colors.secondary}

; Right-memory
[module/memory]
type = internal/memory
interval = 2
format-prefix = "ÓÄ® "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = ${colors.secondary}
label = %percentage_used%%

; Right-cpu
[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "ÓÄ¶ "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = ${colors.secondary}
label = %percentage:2%%

; Right-temp
[module/cpu-temp-script]
type = custom/script
exec = ~/.scripts/tools/polybar-scripts/cpu-temp.sh 
interval = 2

format-prefix = "ÓÉČ "
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = ${colors.secondary}

; Right-eth
[module/eth]
type = internal/network
interface = enp30s0
interval = 2 
;format-connected-underline = ${colors.secondary}
format-connected-prefix = "ÓÜú "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = DL: %downspeed% UP: %upspeed%

;format-disconnected-underline = ${self.format-connected-underline}
format-disconnected = <label-disconnected>
label-disconnected = no internet
label-disconnected-foreground = ${colors.foreground-alt}

; Right-date
[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = ÓÄĖ
format-prefix-foreground = ${colors.foreground-alt}
;format-underline = ${colors.secondary}

label = %date% %time%

; Right-powermenu
[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = ÓĄĆ
label-open-foreground = #e60053
label-close = ÓĀ• cancel
label-close-foreground = #e60053
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

; vim:ft=dosini

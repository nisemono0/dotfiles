! X colors.
*foreground:        #c8c5c4
*background:        #241915
*.foreground:       #c8c5c4
*.background:       #241915
URxvt*foreground:   #c8c5c4
XTerm*foreground:   #c8c5c4
UXTerm*foreground:  #c8c5c4
URxvt*background:   [99]#241915
XTerm*background:   #241915
UXTerm*background:  #241915
URxvt*cursorColor:  #c8c5c4
XTerm*cursorColor:  #c8c5c4
UXTerm*cursorColor: #c8c5c4
URxvt*borderColor:  [99]#241915

! Colors 0-15.
*.color0: #241915
*color0:  #241915
*.color1: #b7826a
*color1:  #b7826a
*.color2: #c5beba
*color2:  #c5beba
*.color3: #a6a294
*color3:  #a6a294
*.color4: #bfb867
*color4:  #bfb867
*.color5: #9faa58
*color5:  #9faa58
*.color6: #b04a5a
*color6:  #b04a5a
*.color7: #c8c5c4
*color7:  #c8c5c4
*.color8: #5a524f
*color8:  #5a524f
*.color9: #b7826a
*color9:  #b7826a
*.color10: #c5beba
*color10:  #c5beba
*.color11: #a6a294
*color11:  #a6a294
*.color12: #bfb867
*color12:  #bfb867
*.color13: #9faa58
*color13:  #9faa58
*.color14: #b04a5a
*color14:  #b04a5a
*.color15: #c8c5c4
*color15:  #c8c5c4

! Black color that will not be affected by bold highlighting.
*.color66: #241915
*color66:  #241915

! Open urls
!URxvt.perl-ext-common: default,matcher
!URxvt.url-launcher: /usr/bin/xdg-open
!URxvt.matcher.button: 1
!URxvt.colorUL: #4682B4

! alternative font settings with 'terminus':
URxvt*font:		-xos4-terminus-medium-r-normal--16-160-72-72-c-80-iso10646-1
URxvt*depth:                      32
URxvt*scrollBar:                  false
URxvt*mouseWheelScrollPage:       false
URxvt*cursorBlink:                false
URxvt*saveLines:                  5000

! Normal copy-paste keybindings without perls
URxvt.iso14755:                   false
URxvt.keysym.Shift-Control-V:     eval:paste_clipboard
URxvt.keysym.Shift-Control-C:     eval:selection_to_clipboard
!Xterm escape codes, word by word movement
URxvt.keysym.Control-Left:        \033[1;5D
URxvt.keysym.Shift-Control-Left:  \033[1;6D
URxvt.keysym.Control-Right:       \033[1;5C
URxvt.keysym.Shift-Control-Right: \033[1;6C
URxvt.keysym.Control-Up:          \033[1;5A
URxvt.keysym.Shift-Control-Up:    \033[1;6A
URxvt.keysym.Control-Down:        \033[1;5B
URxvt.keysym.Shift-Control-Down:  \033[1;6B
! ------------------------------------------------------------------------------
! Xft Font Configuration
! ------------------------------------------------------------------------------

Xft.autohint: 0
Xft.lcdfilter: lcddefault
Xft.hintstyle: hintslight
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb


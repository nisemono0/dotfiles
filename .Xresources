! X colors.
*foreground:        #c9c8c8
*background:        #272525
*.foreground:       #c9c8c8
*.background:       #272525
URxvt*foreground:   #c9c8c8
XTerm*foreground:   #c9c8c8
UXTerm*foreground:  #c9c8c8
URxvt*background:   [99]#272525
XTerm*background:   #272525
UXTerm*background:  #272525
URxvt*cursorColor:  #c9c8c8
XTerm*cursorColor:  #c9c8c8
UXTerm*cursorColor: #c9c8c8
URxvt*borderColor:  [99]#272525

! Colors 0-15.
*.color0: #272525
*color0:  #272525
*.color1: #c5beba
*color1:  #c5beba
*.color2: #c5a46e
*color2:  #c5a46e
*.color3: #a5a294
*color3:  #a5a294
*.color4: #a1a357
*color4:  #a1a357
*.color5: #b6c363
*color5:  #b6c363
*.color6: #b76569
*color6:  #b76569
*.color7: #c9c8c8
*color7:  #c9c8c8
*.color8: #5d5b5b
*color8:  #5d5b5b
*.color9: #c5beba
*color9:  #c5beba
*.color10: #c5a46e
*color10:  #c5a46e
*.color11: #a5a294
*color11:  #a5a294
*.color12: #a1a357
*color12:  #a1a357
*.color13: #b6c363
*color13:  #b6c363
*.color14: #b76569
*color14:  #b76569
*.color15: #c9c8c8
*color15:  #c9c8c8

! Black color that will not be affected by bold highlighting.
*.color66: #272525
*color66:  #272525

! Open urls
!URxvt.perl-ext-common: default,matcher
!URxvt.url-launcher: /usr/bin/xdg-open
!URxvt.matcher.button: 1
!URxvt.colorUL: #4682B4

! Options
URxvt*font:		                  xft:SauceCodePro Nerd Font Mono:pixelsize=14:style=Semibold,Regular,\
								  xft:Noto Sans Mono CJK JP:style=Bold
URxvt*boldFont:                   xft:SauceCodePro Nerd Font Mono:pixelsize=14:style=Black,Regular
URxvt*italicFont:				  xft:SauceCodePro Nerd Font Mono:pixelsize=14:style=Semibold Italic,Italic
URxvt*boldItalicFont:			  xft:SauceCodePro Nerd Font Mono:pixelsize=14:style=Semibold Italic,Italic

URxvt*depth:                      32
URxvt*scrollBar:                  false
URxvt*mouseWheelScrollPage:       false
URxvt*cursorBlink:                false
URxvt*saveLines:                  5000

! Normal copy-paste keybindings without perls
URxvt.iso14755:                   false
URxvt.keysym.Shift-Control-V:     eval:paste_clipboard
URxvt.keysym.Shift-Control-C:     eval:selection_to_clipboard
!Xterm escape codes, word by word movement
URxvt.keysym.Control-Left:        \033[1;5D
URxvt.keysym.Shift-Control-Left:  \033[1;6D
URxvt.keysym.Control-Right:       \033[1;5C
URxvt.keysym.Shift-Control-Right: \033[1;6C
URxvt.keysym.Control-Up:          \033[1;5A
URxvt.keysym.Shift-Control-Up:    \033[1;6A
URxvt.keysym.Control-Down:        \033[1;5B
URxvt.keysym.Shift-Control-Down:  \033[1;6B
! ------------------------------------------------------------------------------
! Xft Font Configuration
! ------------------------------------------------------------------------------

Xft.autohint: 0
Xft.lcdfilter: lcddefault
Xft.hintstyle: hintslight
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb


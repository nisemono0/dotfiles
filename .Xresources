! X colors.
*foreground:        #c7c7c7
*background:        #1f211f
*.foreground:       #c7c7c7
*.background:       #1f211f
URxvt*foreground:   #c7c7c7
XTerm*foreground:   #c7c7c7
UXTerm*foreground:  #c7c7c7
URxvt*background:   [90]#1f211f
XTerm*background:   #1f211f
UXTerm*background:  #1f211f
URxvt*cursorColor:  #c7c7c7
XTerm*cursorColor:  #c7c7c7
UXTerm*cursorColor: #c7c7c7
URxvt*borderColor:	[90]#1f211f

! Colors 0-15.
*.color0: #1f211f
*color0:  #1f211f
*.color1: #9daa9c
*color1:  #9daa9c
*.color2: #a9aaa9
*color2:  #a9aaa9
*.color3: #91aa97
*color3:  #91aa97
*.color4: #a1aaa5
*color4:  #a1aaa5
*.color5: #87aa99
*color5:  #87aa99
*.color6: #a9a6a9
*color6:  #a9a6a9
*.color7: #c7c7c7
*color7:  #c7c7c7
*.color8: #575857
*color8:  #575857
*.color9: #9daa9c
*color9:  #9daa9c
*.color10: #a9aaa9
*color10:  #a9aaa9
*.color11: #91aa97
*color11:  #91aa97
*.color12: #a1aaa5
*color12:  #a1aaa5
*.color13: #87aa99
*color13:  #87aa99
*.color14: #a9a6a9
*color14:  #a9a6a9
*.color15: #c7c7c7
*color15:  #c7c7c7

! Black color that will not be affected by bold highlighting.
*.color66: #1f211f
*color66:  #1f211f

! alternative font settings with 'terminus':
URxvt*font:      -xos4-terminus-medium-r-normal--16-160-72-72-c-80-iso10646-1
URxvt*depth:                      32
URxvt*scrollBar:                  false
URxvt*mouseWheelScrollPage:       false
URxvt*cursorBlink:                false
URxvt*saveLines:                  5000

! Normal copy-paste keybindings without perls
URxvt.iso14755:                   false
URxvt.keysym.Shift-Control-V:     eval:paste_clipboard
URxvt.keysym.Shift-Control-C:     eval:selection_to_clipboard
!Xterm escape codes, word by word movement
URxvt.keysym.Control-Left:        \033[1;5D
URxvt.keysym.Shift-Control-Left:  \033[1;6D
URxvt.keysym.Control-Right:       \033[1;5C
URxvt.keysym.Shift-Control-Right: \033[1;6C
URxvt.keysym.Control-Up:          \033[1;5A
URxvt.keysym.Shift-Control-Up:    \033[1;6A
URxvt.keysym.Control-Down:        \033[1;5B
URxvt.keysym.Shift-Control-Down:  \033[1;6B
! ------------------------------------------------------------------------------
! Xft Font Configuration
! ------------------------------------------------------------------------------

Xft.autohint: 0
Xft.lcdfilter: lcddefault
Xft.hintstyle: hintslight
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb


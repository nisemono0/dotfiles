*foreground:        #e9dece
*background:        #180d0c
*.foreground:       #e9dece
*.background:       #180d0c
URxvt*foreground:   #e9dece
XTerm*foreground:   #e9dece
UXTerm*foreground:  #e9dece
URxvt*background:   [80]#180d0c
XTerm*background:   #180d0c
UXTerm*background:  #180d0c
URxvt*cursorColor:  #e9dece
XTerm*cursorColor:  #e9dece
UXTerm*cursorColor: #e9dece
URxvt*borderColor:  [100]#180d0c
*fading:			8
*fadeColor:			black


*.color0: #180d0c
*color0:  #180d0c
*.color1: #B2A496
*color1:  #B2A496
*.color2: #CDB795
*color2:  #CDB795
*.color3: #E2B797
*color3:  #E2B797
*.color4: #DCC19D
*color4:  #DCC19D
*.color5: #C0C0AC
*color5:  #C0C0AC
*.color6: #D8C7A9
*color6:  #D8C7A9
*.color7: #e9dece
*color7:  #e9dece
*.color8: #a39b90
*color8:  #a39b90
*.color9: #B2A496
*color9:  #B2A496
*.color10: #CDB795
*color10:  #CDB795
*.color11: #E2B797
*color11:  #E2B797
*.color12: #DCC19D
*color12:  #DCC19D
*.color13: #C0C0AC
*color13:  #C0C0AC
*.color14: #D8C7A9
*color14:  #D8C7A9
*.color15: #e9dece
*color15:  #e9dece

! Black color that will not be affected by bold highlighting.
*.color66: #180d0c
*color66:  #180d0c

! alternative font settings with 'terminus':
URxvt*font:      -xos4-terminus-medium-r-normal--16-160-72-72-c-80-iso10646-1
!URxvt*font: -xos4-terminus-bold-r-normal--16-160-72-72-c-80-iso10646-1
URxvt*depth:                      32
URxvt*scrollBar:                  false
URxvt*mouseWheelScrollPage:       false
URxvt*cursorBlink:                false
URxvt*saveLines:                  5000

! Normal copy-paste keybindings without perls
URxvt.iso14755:                   false
URxvt.keysym.Shift-Control-V:     eval:paste_clipboard
URxvt.keysym.Shift-Control-C:     eval:selection_to_clipboard
!Xterm escape codes, word by word movement
URxvt.keysym.Control-Left:        \033[1;5D
URxvt.keysym.Shift-Control-Left:  \033[1;6D
URxvt.keysym.Control-Right:       \033[1;5C
URxvt.keysym.Shift-Control-Right: \033[1;6C
URxvt.keysym.Control-Up:          \033[1;5A
URxvt.keysym.Shift-Control-Up:    \033[1;6A
URxvt.keysym.Control-Down:        \033[1;5B
URxvt.keysym.Shift-Control-Down:  \033[1;6B
! ------------------------------------------------------------------------------
! Xft Font Configuration
! ------------------------------------------------------------------------------

Xft.autohint: 0
Xft.lcdfilter: lcddefault
Xft.hintstyle: hintslight
Xft.hinting: 1
Xft.antialias: 1
Xft.rgba: rgb

